{
  "name": "@merkaly/api",
  "version": "0.6.4",
  "type": "module",
  "description": "Shared TypeScript interfaces and enums for Merkaly API",
  "repository": {
    "type": "git",
    "url": "https://github.com/merkaly-io/api"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "default": "./dist/*/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsx build.ts",
    "prepack": "pnpm build",
    "sync": "bash scripts/sync-from-api-app.sh"
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "changelogen": "^0.6.2",
    "tsx": "^4.0.0",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.28.2"
}
